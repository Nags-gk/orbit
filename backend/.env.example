# ──────────────────────────────────────────────
# Orbit AI Configuration
# Choose ONE of the AI options below.
# ──────────────────────────────────────────────

# ── Option A: Google Gemini (Recommended) ──
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Option B: Anthropic Claude ──
ANTHROPIC_API_KEY=

# ── Option C: Local LLM Privacy Mode (Ollama / LM Studio) ──
# Set USE_LOCAL_LLM=True to disconnect from cloud providers entirely.
# Requires Ollama running: https://ollama.com
USE_LOCAL_LLM=False
LOCAL_MODEL_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1

# ── Option D: No keys at all ──
# Orbit will run in Demo Mode with a keyword-based assistant.
# Fully functional for testing — no AI key required.

# ──────────────────────────────────────────────
# Advanced Configuration (usually no changes needed)
# ──────────────────────────────────────────────

# Database URL — defaults to local SQLite if not set
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/orbit

# Anthropic Model configuration (only used when ANTHROPIC_API_KEY is set)
DEFAULT_MODEL=claude-sonnet-4-20250514
OPUS_MODEL=claude-opus-4-20250514
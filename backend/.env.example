# Anthropic & Gemini API Keys (External cloud models)
ANTHROPIC_API_KEY=sk-ant-xxxxx
GEMINI_API_KEY=your_gemini_api_key_here

# Local LLM Privacy Mode (Ollama / LM Studio)
# Set to True to disconnect from cloud providers and run AI locally
USE_LOCAL_LLM=True
LOCAL_MODEL_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1

# Database URL — defaults to SQLite if not set
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/orbit

# Model configuration
DEFAULT_MODEL=claude-sonnet-4-20250514
OPUS_MODEL=claude-opus-4-20250514